{
  "name": "@spektrum/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared game engine, types, and socket.io contract for Spektrum TCG. Consumed by spektrum-client and spektrum-server.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/engine/index.ts",
    "./types": "./src/types/index.ts",
    "./ai": "./src/ai/index.ts",
    "./data": "./src/data/index.ts",
    "./socket-events": "./src/socket-events.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
